\pard\plain\ltrpar\qj\s28\itap0{\s28\f0\fs28\lang2057{\*\listtag0}\abinodiroverride\ltrch Jona pala: \uc1\u8220\'93Dez lima mwen saba si ach. Nai mi re ach sat di vakti! Mi xa fa ke?\uc1\u8221\'94}{\s28\f0\fs28\lang2057{\*\listtag0}\par}
\pard\plain\ltrpar\qj\s28\itap0{\s28\f0\fs28\lang2057{\*\listtag0}\par}
